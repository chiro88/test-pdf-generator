# Regenerable RTM factory output (rebuild with: python rtm_factory/generate.py)
picker_cmc_v1/tests/fixtures/rtm_gallery/

# rtm_frozen/ stays commit-eligible: it becomes the durable, human-reviewed
# (Gate B) golden fixture set for the detector. Only --keep demo / scratch
# output is ignored, under a separate dir, so real frozen fixtures can be
# committed without `git add -f`.
picker_cmc_v1/tests/fixtures/rtm_frozen_demo/

# Detector-vs-truth comparison artifacts + real-PDF review packages (regenerable,
# may contain renders of copyrighted user PDFs) — never committed.
artifacts/

# User-provided / sample real PDFs (D17 smoke inputs) — never commit the PDF itself.
pdf/
*.input.pdf

